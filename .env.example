# Public site URL — used for canonical/OG/sitemap absolute URLs.
NEXT_PUBLIC_SITE_URL=https://apewise.ai

# Every /api/waitlist signup is appended to a durable local JSONL file
# (default ./data/waitlist.jsonl — gitignored, survives restarts + deploys).
# Uncomment to store it somewhere else.
# WAITLIST_FILE=/var/www/apewise/data/waitlist.jsonl

# Optional: ALSO forward each validated signup to this webhook (Sheets/Zapier/CRM/ESP).
WAITLIST_WEBHOOK_URL=

# Optional analytics (privacy-friendly Plausible). Set to your site domain to enable
# pageviews + the "Waitlist Signup" goal. Leave unset to disable analytics entirely.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=apewise.ai
# Self-hosted Plausible only — full script URL:
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.tagged-events.js

# ───────────────────────── MVP: smart-money engine (Solana / Helius) ─────────
# Without these, the /terminal stays in DEMO mode and no alerts are sent.
#
# CHOOSE ONE INGEST MODE — do NOT run both:
#   A) Webhook (recommended): Helius PUSHES swaps only when a tracked wallet
#      trades. Scales to 100s of wallets cheaply — you pay per real swap, not
#      per poll. Set HELIUS_API_KEY + run setup-helius-webhook.mjs, and do NOT
#      run the apewise-rpc worker (pm2 stop apewise-rpc).
#   B) RPC poll (free fallback): the apewise-rpc worker PULLS every wallet every
#      cycle (see the bottom section). Use a FREE public RPC for this — pointing
#      it at a paid Helius RPC burns credits even when nothing trades.
#
# Helius API key — creates the webhook + provides RPC. https://helius.xyz
HELIUS_API_KEY=
# Public URL of the ingest endpoint (used by scripts/setup-helius-webhook.mjs)
WEBHOOK_URL=https://apewise.ai/api/ingest/helius
# Shared secret: Helius sends it as the webhook authHeader; /api/ingest/helius checks it.
INGEST_SECRET=
# Telegram bot that posts to the signals channel, + the channel/chat id (e.g. @apewisesignals)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SIGNALS_CHAT_ID=@apewisesignals
# Webhook secret for the bot command handler (any random string)
TELEGRAM_WEBHOOK_SECRET=
# Channel alerts: min buy size to broadcast + worker poll interval
# ALERT_MIN_USD=1000
# ALERT_INTERVAL_SEC=60
# Optional referral "Buy" link template ({mint} is replaced). Defaults to a DexScreener link.
# BUY_LINK_TEMPLATE=https://t.me/your_trojan_bot?start={mint}
# Optional overrides
# SOL_PRICE_USD=150
# SMART_WALLETS_FILE=data/smart-wallets.json
# EVENTS_FILE=data/events.jsonl
# Anti-rug / alert tuning
# MIN_LIQUIDITY_USD=5000          # below this, a token is flagged "caution"
# ALERT_COOLDOWN_SEC=60           # min seconds between alerts for the same wallet+token
# ALERT_ON_RISK=false             # set "true" to alert even on high-risk tokens
# MIN_TRADE_USD=50                # live-market feed: hide trades smaller than this
# USE_GMGN_WALLETS=true           # auto-source smart wallets from GMGN's leaderboard (Cloudflare may block server-side)
# BIRDEYE_API_KEY=                # smart-money leaderboard via Birdeye (free key, no Cloudflare) — recommended
# BIRDEYE_TRACK_LIMIT=50          # setup-helius-webhook: how many top Birdeye wallets to track (paged 10/call)
# USE_ACTIVE_TRADERS=true         # setup-helius-webhook: ALSO track wallets actively trading trending tokens (GeckoTerminal, free) — populates the feed beyond quiet whales
# ACTIVE_MIN_USD=1000             # min trade size (USD) to source an active trader
# ACTIVE_POOLS=15                 # how many trending pools to scan for active traders
# Non-Solana chains push normalized events to POST /api/ingest/event (same INGEST_SECRET).

# ── MODE B — Free no-Helius fallback: poll tracked wallets via public Solana RPC
# Run the worker:  pm2 start scripts/rpc-poll-worker.mjs --name apewise-rpc && pm2 save
# Smart-money swaps then flow in without a Helius webhook, at the cost of
# ~poll-interval latency. Tracks data/smart-wallets.json.
# ⚠️ Use a FREE public RPC here. This worker pulls EVERY wallet EVERY cycle, so a
#    paid Helius RPC burns credits on idle polling — if you have Helius, use the
#    webhook (Mode A) and `pm2 stop apewise-rpc` instead.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com  # FREE public RPC (or another free one)
# RPC_POLL_INTERVAL_SEC=30        # how often the worker polls all wallets
# RPC_SIGS_PER_WALLET=10          # newest signatures fetched per wallet per cycle (max 25)
# RPC_CALL_DELAY_MS=150           # spacing between RPC calls (stay under public-RPC limits)
# RPC_LOOKBACK_MIN=20             # on (re)start, surface swaps from the last N min immediately
# RPC_MAX_AGE_MIN=120             # ignore swaps older than this (ongoing staleness guard)
# RPC_MAX_WALLETS=60              # cap wallets polled per cycle
